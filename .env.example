# ElevenLabs API Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice IDs for each supported language
# Find voice IDs at: https://elevenlabs.io/app/voice-library
# Recommended calm/soothing voices for "goodnight read" style:
#   - Rachel (English): 21m00Tcm4TlvDq8ikWAM  (calm, warm, soothing)
#   - Matilda (English): XrExE9yKIg1WjnnlVkGX (soft, gentle)
#   - Alice (English): Xb7hH8MSUJpSbSDYk0k2 (friendly, warm)
VOICE_ID_EN=21m00Tcm4TlvDq8ikWAM

# Polish voice (ElevenLabs supports Polish natively)
# Recommended: use a multilingual v2 model which handles Polish well
VOICE_ID_PL=21m00Tcm4TlvDq8ikWAM

# Spanish voice
VOICE_ID_ES=21m00Tcm4TlvDq8ikWAM

# ElevenLabs Model Configuration
# eleven_multilingual_v2 supports: EN, PL, ES, DE, FR, IT, PT, HI, AR, CS, ZH, JA, HU, KO, NL, TR
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Audio Settings
AUDIO_OUTPUT_FORMAT=mp3_44100_128
OUTPUT_DIR=./output

# Service Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
