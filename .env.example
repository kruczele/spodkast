# ElevenLabs API Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice IDs for each supported language
# Find voice IDs at: https://elevenlabs.io/app/voices
#
# FREE TIER NOTE: Library voices (Rachel 21m00Tcm4TlvDq8ikWAM etc.) require a paid plan
# for API access. The voices below are available on the free tier:
#
# Recommended calm/soothing voices for "goodnight read" style (free tier compatible):
#   - Sarah:   EXAVITQu4vr4xnSDxMaL  (mature, reassuring, confident — TESTED ✓)
#   - Matilda: XrExE9yKIg1WjnnlVkGX  (knowledgeable, professional)
#   - Alice:   Xb7hH8MSUJpSbSDYk0k2  (clear, engaging)
#   - Lily:    pFZP5JQG7iQjIQuC4Bku  (velvety actress — very soothing)
#   - George:  JBFqnCBsd6RMkjVDRZzb  (warm, captivating storyteller)
#
# With a paid plan, also consider:
#   - Rachel: 21m00Tcm4TlvDq8ikWAM  (calm, warm, soothing — requires paid API)
#
# For multilingual (PL, ES) the eleven_multilingual_v2 model handles all languages.
# Any voice ID above will work for Polish/Spanish with that model.
VOICE_ID_EN=EXAVITQu4vr4xnSDxMaL

# Polish voice (ElevenLabs supports Polish natively via eleven_multilingual_v2)
VOICE_ID_PL=EXAVITQu4vr4xnSDxMaL

# Spanish voice
VOICE_ID_ES=EXAVITQu4vr4xnSDxMaL

# ElevenLabs Model Configuration
# eleven_multilingual_v2 supports: EN, PL, ES, DE, FR, IT, PT, HI, AR, CS, ZH, JA, HU, KO, NL, TR
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Audio Settings
AUDIO_OUTPUT_FORMAT=mp3_44100_128
OUTPUT_DIR=./output

# Service Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
