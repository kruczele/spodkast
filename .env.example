# ElevenLabs API Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Anthropic API (required for LLM-based script generation via /podcast/generate)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Voice IDs for each supported language
# Find voice IDs at: https://elevenlabs.io/app/voice-library
# Defaults are tuned for "fun facts for bedtime" — soft, calm, sleep-friendly narration.
#   - Nicole (EN): piTKgcLEGmPE4e6mEKli — whispery ASMR voice, ideal for sleep content
#   - Nicole: piTKgcLEGmPE4e6mEKli — whispery ASMR voice; eleven_multilingual_v2 handles all languages
VOICE_ID_EN=piTKgcLEGmPE4e6mEKli
VOICE_ID_PL=piTKgcLEGmPE4e6mEKli
VOICE_ID_ES=piTKgcLEGmPE4e6mEKli

# ElevenLabs Model Configuration
# eleven_multilingual_v2 supports: EN, PL, ES, DE, FR, IT, PT, HI, AR, CS, ZH, JA, HU, KO, NL, TR
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Audio Settings
AUDIO_OUTPUT_FORMAT=mp3_44100_128
OUTPUT_DIR=./output

# Database Settings
# Path to the SQLite database file that persists sessions and jobs across restarts.
# For multi-device access on a shared filesystem, point this to a shared path.
DB_PATH=./spodkast.db

# Service Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
